      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "OFF",
        "NUEDC_TEST_MOTOR": "ON",
        "NUEDC_TEST_OLED_IMU": "OFF",
        "NUEDC_TEST_TURN": "OFF",
        "NUEDC_TEST_ENCODER_IMU": "OFF"
      }
    },
    {
      "name": "oled-imu-test",
      "displayName": "OLED ICM45688 Yaw Test",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-oled-imu-test",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "OFF",
        "NUEDC_TEST_MOTOR": "OFF",
        "NUEDC_TEST_OLED_IMU": "ON",
        "NUEDC_TEST_TURN": "OFF",
        "NUEDC_TEST_ENCODER_IMU": "OFF"
      }
    },
    {
      "name": "turn-test",
      "displayName": "Button IMU Turn Test",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-turn-test",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "OFF",
        "NUEDC_TEST_MOTOR": "OFF",
        "NUEDC_TEST_OLED_IMU": "OFF",
        "NUEDC_TEST_TURN": "ON",
        "NUEDC_TEST_ENCODER_IMU": "OFF"
      }
    },
    {
      "name": "encoder-imu-test",
      "displayName": "Motor Encoder IMU Test",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-encoder-imu-test",
