{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mspm0-gcc-debug",
      "displayName": "MSPM0 Main Firmware (Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-fw",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "OFF",
        "NUEDC_TEST_MOTOR": "OFF",
        "NUEDC_TEST_OLED_IMU": "OFF",
        "NUEDC_TEST_TURN": "OFF",
        "NUEDC_TEST_ENCODER_IMU": "OFF"
      }
    },
    {
      "name": "line-sensor-test",
      "displayName": "Digital Grayscale Test",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-line-sensor-test",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "ON",
        "NUEDC_TEST_MOTOR": "OFF",
        "NUEDC_TEST_OLED_IMU": "OFF",
        "NUEDC_TEST_TURN": "OFF",
        "NUEDC_TEST_ENCODER_IMU": "OFF"
      }
    },
    {
      "name": "motor-test",
      "displayName": "Button Motor Test",
      "generator": "Ninja",
