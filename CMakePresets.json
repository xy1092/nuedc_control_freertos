      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NUEDC_TEST_LINE_SENSOR": "OFF",
        "NUEDC_TEST_MOTOR": "OFF",
        "NUEDC_TEST_OLED_IMU": "OFF",
        "NUEDC_TEST_TURN": "OFF",
        "NUEDC_TEST_ENCODER_IMU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "main-build",
      "configurePreset": "mspm0-gcc-debug"
    },
    {
      "name": "line-sensor-build",
      "configurePreset": "line-sensor-test"
    },
    {
      "name": "motor-test-build",
      "configurePreset": "motor-test"
    },
    {
      "name": "oled-imu-test-build",
      "configurePreset": "oled-imu-test"
    },
    {
      "name": "turn-test-build",
      "configurePreset": "turn-test"
    },
    {
      "name": "encoder-imu-test-build",
